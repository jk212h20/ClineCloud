# ClineCloud Configuration
PORT=3000
PIN=change-me-to-a-secure-pin

# GitHub Personal Access Token (for cloning/pushing repos)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx

# Cline CLI API key (PPQ.ai gateway)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Data directory (volume mount on Railway)
DATA_DIR=/data

# Cline CLI path (auto-installed via nixpacks)
CLINE_PATH=cline

# Task defaults
DEFAULT_TIMEOUT=600
MAX_QUEUE_SIZE=10
